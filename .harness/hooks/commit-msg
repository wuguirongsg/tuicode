#!/bin/sh
MSG=$(cat "$1")
if ! echo "$MSG" | grep -qE "^(feat|fix|docs|refactor|test|chore|style|perf|session|discover|design|verify|release|retro):"; then
  echo ""
  echo "⚠️  [harness] commit message 格式不符合规范"
  echo "    格式：<type>: <描述>"
  echo "    type 可选：feat / fix / docs / refactor / test / chore / style / perf / session"
  echo "              discover / design / verify / release / retro（对应开发阶段）"
  echo ""
  exit 1
fi
