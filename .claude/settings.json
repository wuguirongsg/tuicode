{
  "env": {
    "CLAUDE_CODE_HOOKS": "1"
  },

  "hooks": {

    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/hooks/session-start.sh",
            "additionalContext": true,
            "timeout": 10
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/hooks/guard-dangerous.sh",
            "timeout": 5
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/hooks/post-write.sh",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/hooks/session-end.sh",
            "additionalContext": true,
            "timeout": 10
          }
        ]
      }
    ]

  }
}
