{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash .harness/hooks/session-start.sh",
          "timeout": 10
        }
      ]
    }
  ],

  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash .harness/hooks/guard-dangerous.sh",
          "timeout": 5
        }
      ]
    }
  ],

  "PostToolUse": [
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash .harness/hooks/post-write.sh",
          "timeout": 15
        }
      ]
    }
  ],

  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash .harness/hooks/session-end-codex.sh",
          "timeout": 10
        }
      ]
    }
  ]
}
